# Default: Ollama Cloud (https://ollama.com) - requires an account + API key, no local
# download/GPU needed. gpt-oss:120b was empirically validated as the best free-tier model
# for this use case (reliable JSON-schema compliance + correct NEET-level numericals).
# To run fully local instead: set OLLAMA_HOST=http://localhost:11434, leave OLLAMA_API_KEY
# blank, and `ollama pull` a model of your choice (see README for trade-offs).
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

DB_PATH=./data/neet.db
TAXONOMY_PATH=./data/taxonomy.json
LLM_CALL_LOG_PATH=./data/llm_call_log.jsonl

GENERATOR_BATCH_SIZE=3
POOL_QUESTIONS_PER_CONCEPT=4
QUESTIONS_PER_SESSION=10
